# Supabase — copy to .env and fill in (the real .env is gitignored, never commit it)
# Find these in: Supabase Dashboard -> Project Settings -> API

# Project ref: olwftiuxzjdhsnvllzif
SUPABASE_URL=https://olwftiuxzjdhsnvllzif.supabase.co

# Public anon key — safe for client/browser use (RLS still applies)
SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY, bypasses RLS. Never expose to the frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Personal access token for the Supabase CLI / MCP server.
# Generate at: https://supabase.com/dashboard/account/tokens
# Each teammate creates their OWN token — do not share.
SUPABASE_ACCESS_TOKEN=

# Direct Postgres connection string (Dashboard -> Project Settings -> Database).
# Use the Session pooler / connection string; keep the password out of git.
DATABASE_URL=

# ============================================================================
# Dashboard (Next.js) — copy these into dashboard/.env.local
# ============================================================================
# Mirror of the public vars, prefixed for the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=https://olwftiuxzjdhsnvllzif.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Public site URL for Supabase OAuth + email OTP redirects. Optional locally
# (falls back to the current origin). Set explicitly in production on Vercel
# and redeploy so NEXT_PUBLIC_* is baked into the build.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Apify token — Settings -> Integrations on apify.com
APIFY_TOKEN=

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
# VOICE_ID defaults to "JBFqnCBsd6RMkjVDRZzb" (a built-in studio voice).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Google AI Studio — free tier covers gemini-2.5-flash-image (Nano-banana)
# AND gemini-2.5-flash (text). Used for:
#   - Step 3 AI script + beats (gemini-2.5-flash, JSON-structured output)  <-- ALWAYS Google
#   - Step 4 per-beat images   (only when IMAGE_PROVIDER=google)
#   - Step 6 motion clips       (only when VIDEO_PROVIDER=google-veo, 2 RPM / 9 RPD)
# Get one at https://aistudio.google.com/app/apikey
# NOTE: still required even on the fal setup — Step 3 (script/beats) uses Gemini text.
GOOGLE_API_KEY=

# ============================================================================
# fal.ai — the DEFAULT generation engine for images (Step 4) + video (Step 6).
# One key powers both. Pay-per-use, no subscription, no rate-limit cliff.
#   - Images: Nano Banana 2     (~$0.08/image)
#   - Video:  Veo 3.1 Lite      (4s, muted, 720p, ~$0.20/clip)
# Create a key at https://fal.ai/dashboard/keys, then TOP UP credits.
# SERVER ONLY — never expose to the frontend.
# ============================================================================
FAL_KEY=
# Optional fal overrides (sensible defaults are baked in — only set to change):
# IMAGE_PROVIDER=fal              # fal (default) | google (free Gemini fallback)
# FAL_VIDEO_MODEL=fal-ai/veo3.1/lite/image-to-video
# FAL_DURATION_SECONDS=4          # 4 or 8
# FAL_RESOLUTION=720p             # 720p (cheap, default) | 1080p

# Step 6 video provider. Options:
#   - fal               (DEFAULT) Veo 3.1 Lite on fal, 4s muted 720p, ~$0.20/clip.
#                       Needs FAL_KEY (above). Cheapest end-to-end, no throttle.
#   - replicate-kling   Kling v2.6 Pro, ~$0.25 / 5s 1080p. Best face consistency.
#   - replicate-ltx     LTX-Video, ~$0.05 / 5s. Cheap, visibly worse fidelity.
#   - google-veo        Veo 3 Fast, ~$0.50–$1 / 4s. 2 RPM / 9 RPD on free key.
# Replicate's free tier (<$5 credit) throttles to 6 RPM / burst 1 (sequential).
# VIDEO_PROVIDER=fal

# Replicate — https://replicate.com/account/api-tokens
# Required when VIDEO_PROVIDER=replicate-ltx (the default).
REPLICATE_API_TOKEN=
# Override only if you want a different LTX version. Format: owner/name:version.
# REPLICATE_LTX_MODEL=lightricks/ltx-video:8c47da666861d081eeb4d1261853087de23923a268a69b63febdf5dc1dee08e4

# Optional Veo overrides (used only when VIDEO_PROVIDER=google-veo).
# VEO_MODEL=veo-3.0-fast-generate-001       # or "veo-3.0-generate-001" for higher quality
# VEO_DURATION_SECONDS=4                     # 4 or 8
