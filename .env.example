# Supabase — copy to .env and fill in (the real .env is gitignored, never commit it)
# Find these in: Supabase Dashboard -> Project Settings -> API

# Project ref: olwftiuxzjdhsnvllzif
SUPABASE_URL=https://olwftiuxzjdhsnvllzif.supabase.co

# Public anon key — safe for client/browser use (RLS still applies)
SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY, bypasses RLS. Never expose to the frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Personal access token for the Supabase CLI / MCP server.
# Generate at: https://supabase.com/dashboard/account/tokens
# Each teammate creates their OWN token — do not share.
SUPABASE_ACCESS_TOKEN=

# Direct Postgres connection string (Dashboard -> Project Settings -> Database).
# Use the Session pooler / connection string; keep the password out of git.
DATABASE_URL=

# ============================================================================
# Dashboard (Next.js) — copy these into dashboard/.env.local
# ============================================================================
# Mirror of the public vars, prefixed for the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=https://olwftiuxzjdhsnvllzif.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Apify token — Settings -> Integrations on apify.com
APIFY_TOKEN=

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
# VOICE_ID defaults to "JBFqnCBsd6RMkjVDRZzb" (a built-in studio voice).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
